# ─────────────────────────────────────────────
#  CONFIGURAÇÕES DO SEU CONTO
# ─────────────────────────────────────────────

# Título do conto (aparece na mensagem de entrega)
CONTO_TITLE=Nome do Seu Conto

# Link de acesso ao conto (pode ser um PDF no Google Drive, Notion, etc.)
CONTENT_URL=https://drive.google.com/file/d/SEU_ID_AQUI

# ─────────────────────────────────────────────
#  DADOS DO PIX
# ─────────────────────────────────────────────

# Sua chave Pix (CPF, e-mail, telefone ou chave aleatória)
PIX_KEY=seu@email.com

# Valor exato do conto (use ponto como separador decimal)
PIX_VALUE=9.90

# Nome EXATO do destinatário como aparece no comprovante
PIX_RECIPIENT_NAME=SEU NOME COMPLETO

# ─────────────────────────────────────────────
#  UAZAPI (SEU BOT DO WHATSAPP)
# ─────────────────────────────────────────────

# URL base do seu servidor UazAPI
# Exemplo: https://seu-bot.railway.app
UAZAPI_URL=https://SEU-UAZAPI-AQUI

# Nome da instância criada no UazAPI
UAZAPI_INSTANCE=minha-instancia

# Token de segurança do UazAPI
UAZAPI_TOKEN=SEU_TOKEN_AQUI

# ─────────────────────────────────────────────
#  ANTHROPIC (IA QUE ANALISA OS COMPROVANTES)
# ─────────────────────────────────────────────

# Crie sua chave em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXX

# ─────────────────────────────────────────────
#  VERCEL KV (BANCO DE DADOS GRATUITO)
# ─────────────────────────────────────────────
# Essas variáveis são geradas automaticamente quando você
# cria um banco KV no painel da Vercel. Não precisa preencher manualmente.

KV_REST_API_URL=https://SEU-KV.kv.vercel-storage.com
KV_REST_API_TOKEN=SEU_TOKEN_KV
